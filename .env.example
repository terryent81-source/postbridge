NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

SUPABASE_SERVICE_ROLE_KEY=
CLEANUP_SECRET=
SCHEDULED_PUBLISH_SECRET=

UPLOAD_MODE=mock
META_UPLOAD_MODE=mock
YOUTUBE_UPLOAD_MODE=mock
TIKTOK_UPLOAD_MODE=mock
META_GRAPH_API_VERSION=v25.0

META_CLIENT_ID=your_meta_app_id
META_CLIENT_SECRET=your_meta_app_secret
META_CONFIG_ID=your_meta_business_login_config_id
META_REDIRECT_URI=http://localhost:3000/api/auth/meta/callback

GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/auth/youtube/callback
YOUTUBE_UPLOAD_SCOPE=https://www.googleapis.com/auth/youtube.upload
YOUTUBE_READ_SCOPE=https://www.googleapis.com/auth/youtube.readonly
YOUTUBE_DEFAULT_PRIVACY_STATUS=private

TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=http://localhost:3000/api/auth/tiktok/callback
TIKTOK_SCOPES=user.info.basic,video.upload,video.publish
